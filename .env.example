# Telegram
BOT_TOKEN=
# Format: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://antispam:antispam@tgguardbot-postgres:5432/antispam
# Format: redis://host:6379
REDIS_URL=redis://tgguardbot-redis:6379

# Comma-separated Telegram user IDs of bot owners
SUPER_ADMIN_IDS=123456789,987654321

# Free-tier (non-approved, non-subscribed) limits
FREE_TIER_MAX_USERS=300
FREE_TIER_MAX_MSGS_PER_HOUR=500

# LLM (reserved, not active in MVP — kept off by default)
LLM_ENABLED=false
LLM_PROVIDER=
LLM_API_KEY=

# Logging
LOG_LEVEL=info
# Set to "true" only in development for pretty logs
LOG_PRETTY=false

# Optional: max captcha attempts before kick (default 3)
CAPTCHA_MAX_ATTEMPTS=3
# Optional: captcha timeout in seconds (default 60)
CAPTCHA_TIMEOUT_SEC=60
# Optional: enable Combot Anti-Spawn (CAS) check for new members (default true)
CAS_CHECK_ENABLED=true

# Optional: Telegram API mirror/proxy. Leave empty to use the default
# https://api.telegram.org. Applies to the bot (long polling, /backup upload)
# and to the pg-backup cron container.
# Example: https://your-proxy.example.com
GRASPIL_PROXY_URL=

# ---- Backups (pg-backup container) ----
# Telegram bot token used by the backup container (defaults to BOT_TOKEN above
# in docker-compose, so you usually don't need to set this separately).
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram chat IDs that receive automated backups.
# If empty, docker-compose falls back to SUPER_ADMIN_IDS (each owner in DM).
TELEGRAM_LOG_CHAT_ID=
# Optional: forum/topic thread id inside TELEGRAM_LOG_CHAT_ID to post backups to.
TELEGRAM_THREAD_ID_BACKUPS=
# Cron schedule for automated backups (default: every 6 hours).
# Standard 5-field crontab: minute hour day-of-month month day-of-week
CRON_SCHEDULE=0 */6 * * *
